# Computational biology artifacts
*.log
*.tmp
*.bak
__pycache__/
*.pyc
.ipynb_checkpoints/
.Rhistory
.RData
.Rproj.user/

# Large intermediate files (keep final outputs only)
*.dcd
*.xtc
*.trr
*.nc
*.h5
*.hdf5
*.sqlite
*.sqlite3
*.db

# Docking intermediate files
*.dlg
*.pdbqt.tmp
*.glg

# MD-related (block generated topology/coord/trajectory outputs from MD runs)
*.top
*.gro
*.mdp
*.xtc
*.trr
*.edr
*.tpr
*.cpt

# Phase 6 MD scaffold: whitelist authored parameter files + inputs
!phase6_md/mdp/*.mdp
!phase6_md/inputs/**/*.pdb
!phase6_md/inputs/**/*.smi

# OS / editor
.DS_Store
Thumbs.db
*.swp
*.swo
*~
.vscode/
.idea/

# Credentials — never commit
.env
*.pem
*.key
.git-credentials
*_PAT*
*token*
