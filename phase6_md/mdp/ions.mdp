; Phase 6 MD — ions.mdp
; Used only for genion (short dummy EM before ion addition)
; AMBER99SB-ILDN + TIP3P conventions

integrator      = steep
emtol           = 1000.0
emstep          = 0.01
nsteps          = 50000

nstlist         = 10
cutoff-scheme   = Verlet
ns_type         = grid
coulombtype     = cutoff
rcoulomb        = 1.0
rvdw            = 1.0
pbc             = xyz
